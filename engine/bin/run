#!/usr/bin/env bb
;; run — the directory-algorithm run driver. Two phases, operator in the loop.
;;
;; The engine (bin/, workflows/, gate/) is flow-agnostic; a flow (flows/<name>/) supplies
;; flow.ron, the contracts, references, and stage dirs. --flow selects one, default
;; rust-factory. A new pipeline is a new flow dir — never an engine change.
;;
;;   bin/run setup   --project P --spec S [--flow NAME] [--arm folder] [--round R]
;;       Generate a run instance under the run root, snapshot the flow's files, add a
;;       git worktree of P on a fresh branch, and print how to drive it. Refuses on a
;;       dirty target working tree — commit or stash first.
;;       Run root = $DA_RUN_ROOT, else ~/.cache/directory-algorithm/runs. NOT /tmp: a
;;       real-disk root is required — builds (esp-idf toolchain + cargo target, many GB)
;;       overflow a small RAM-backed tmpfs and hit its quota.
;;   bin/run capture --run RUNDIR [--round R]
;;       Assemble the immutable run record (manifest, result.patch, gate-report, traces)
;;       under <records-root>/experiments/<round>/runs/<run-id>/ (records-root =
;;       $DA_RECORDS, else ~/.local/share/da-run/records).
;;   bin/run seal    --run RUNDIR [--stage NAME]
;;       Commit whatever the stage left in the worktree and refresh worktree.patch,
;;       then publish to the mirror. Run after every stage: `git diff` alone omits
;;       untracked files, so unsealed work is invisible to both record and mirror.
;;   bin/run gate    --run RUNDIR
;;       Seal, run the flow's gate script, and write its report with the sealed
;;       worktree's identity — so a verdict can never describe code the gate did
;;       not see. Exits with the gate's own status.
;;   bin/run squash  --run RUNDIR
;;       Soft-reset the stage commits back to the base commit, leaving every change
;;       staged, so the commit stage writes exactly one clean commit. Content — and
;;       so the worktree identity — is unchanged; refuses if that is ever untrue.
;;   bin/run restore --run-id RUNID [--into DIR]
;;       Rebuild a mirrored run on this machine: algorithm contracts from this repo,
;;       run.edn/flow.ron/spec/stage outputs from the DaRun mirror (needs
;;       DA_STEER_INGRESS). The worktree is rebuilt from the base commit plus
;;       worktree.patch when a clone holding that base is present.
;;   bin/run --selftest
;;
;; Provenance model: ADR-0006. code -> the project's git AND worktree.patch (the branch
;; is never pushed, so the patch is what crosses hosts); ephemera -> the run dir;
;; provenance + traces -> the frozen run record.

(require '[clojure.string :as str]
         '[clojure.edn :as edn]
         '[babashka.fs :as fs]
         '[babashka.process :as p]
         '[cheshire.core :as json])

;; ---- pure core -----------------------------------------------------------

(defn munge-cwd
  "Claude Code stores a session under ~/.claude/projects/<munged cwd>/."
  [path]
  (str/replace (str path) #"[^A-Za-z0-9]" "-"))

(defn run-id [project-name millis] (str millis "-" project-name))

(defn branch-name [rid] (str "da/" rid))

(defn working-tree-dirty?
  "True when `git status --porcelain` output signals uncommitted or untracked
   changes; a blank result means a clean tree."
  [porcelain]
  (not (str/blank? porcelain)))

(defn parse-flags
  "argv -> {:cmd s, <flag-keyword> value ...}. First non---flag token is :cmd."
  [argv]
  (loop [xs argv, acc {}]
    (if (empty? xs)
      acc
      (let [x (first xs)]
        (cond
          (= x "--selftest") (recur (rest xs) (assoc acc :cmd "selftest"))
          (str/starts-with? x "--") (recur (drop 2 xs)
                                           (assoc acc (keyword (subs x 2)) (second xs)))
          (not (:cmd acc)) (recur (rest xs) (assoc acc :cmd x))
          :else (recur (rest xs) acc))))))

(defn manifest
  [{:keys [run-id project branch base-commit algorithm-version contracts spec arm round created phase steers]}]
  {:run-id run-id
   :arm arm
   :round round
   :phase (or phase "steady-state")   ; convergence (evolving to settle) vs steady-state (one clean run)
   :created created
   :target {:project project :branch branch :base-commit base-commit}
   :algorithm {:version algorithm-version :contracts contracts}
   :spec spec
   ;; F7/ADR-0029: steer-requests raised during the run — correction-steer events on the
   ;; ADR-0010 meter, frozen with the record so the ratchet can be computed later.
   :steers {:count (count (or steers [])) :stages (vec (or steers []))}})

;; ---- selftest ------------------------------------------------------------

(defn selftest []
  (assert (= "-tmp-run-1" (munge-cwd "/tmp/run 1")))
  (assert (= "123-proj" (run-id "proj" 123)))
  (assert (= "da/123-proj" (branch-name (run-id "proj" 123))))
  (assert (not (working-tree-dirty? "")))               ; zero changes -> clean
  (assert (working-tree-dirty? " M Cargo.toml"))        ; one change   -> dirty
  (assert (working-tree-dirty? " M a\n?? b/\n M c"))     ; many changes -> dirty
  (let [f (parse-flags ["setup" "--project" "/p" "--arm" "folder"])]
    (assert (= "setup" (:cmd f)))
    (assert (= "/p" (:project f)))
    (assert (= "folder" (:arm f))))
  (assert (= "capture" (:cmd (parse-flags ["capture" "--run" "/r"]))))
  (let [m (manifest {:run-id "r" :project "/p" :branch "da/r" :base-commit "abc"
                     :algorithm-version "v" :contracts ["CLAUDE.md"] :spec "s" :arm "folder"
                     :round "round-0" :created "t"})]
    (assert (= "abc" (get-in m [:target :base-commit])))
    (assert (= ["CLAUDE.md"] (get-in m [:algorithm :contracts])))
    (assert (= "steady-state" (:phase m)))                           ; defaults when unset
    (assert (= 0 (get-in m [:steers :count]))))                      ; zero steers -> counted zero
  (assert (= "convergence" (:phase (manifest {:phase "convergence"})))) ; passes through
  (let [m (manifest {:steers ["02-tests"]})]                         ; one steer
    (assert (= 1 (get-in m [:steers :count])))
    (assert (= ["02-tests"] (get-in m [:steers :stages]))))
  (assert (= 2 (get-in (manifest {:steers ["01-design" "02-tests"]}) [:steers :count]))) ; many
  (println (json/generate-string {:selftest "ok"})))

;; ---- shell helpers -------------------------------------------------------

(defn sh [& args]
  (let [{:keys [out err exit]} (apply p/sh args)]
    {:out (str/trim (or out "")) :err (str/trim (or err "")) :exit exit}))

(defn engine-root
  "The engine: bin/, workflows/, gate/, fixtures/. Never flow content."
  []
  (-> *file* fs/absolutize fs/normalize fs/parent fs/parent str))

(defn repo-root [] (-> (engine-root) fs/parent str))

(defn flows-root [] (str (repo-root) "/flows"))

;; The flow used when --flow is not given.
(def default-flow "rust-factory")

(defn resolve-flow
  "--flow is a name under flows/ or an absolute path to a flow dir. A flow is
   the skill half: flow.ron, the contracts, references, and stages."
  [flow]
  (let [name (or flow default-flow)
        dir  (if (str/starts-with? name "/") name (str (flows-root) "/" name))]
    (when-not (fs/directory? dir)
      (throw (ex-info (str "no flow at " dir " — available: "
                           (str/join ", " (sort (map fs/file-name (fs/list-dir (flows-root))))))
                      {})))
    (when-not (fs/exists? (str dir "/flow.ron"))
      (throw (ex-info (str dir " holds no flow.ron — not a flow dir") {})))
    dir))

(defn flow-files
  "Everything a flow contributes to a run dir. Read from the flow, never a
   hardcoded list, so a flow may add its own contracts without engine changes."
  [flow-dir]
  (->> (fs/list-dir flow-dir) (map fs/file-name) (map str) sort vec))

(defn records-root [] (or (System/getenv "DA_RECORDS")
                          (str (fs/home) "/.local/share/da-run/records")))

;; flow.ron is the pipeline definition (stages, dispatch kinds, ordering
;; guards) — snapshotted with the run so every run dir is self-describing.

(defn validate-flow!
  "Fail-fast load-time validation: bin/state parses and validates flow.ron
   (exit 0) or explains why not (exit 2). A bad flow never becomes a run."
  [flow-dir]
  (let [r (sh (str (engine-root) "/bin/state") "flow" "--file" (str flow-dir "/flow.ron"))]
    (when-not (zero? (:exit r))
      (throw (ex-info (str "flow.ron failed validation:\n"
                           (:out r) (when (seq (:err r)) (str "\n" (:err r)))) {})))
    (json/parse-string (:out r) true)))

(defn run-flow
  "The run's validated flow, as data. bin/state is the only parser."
  [run]
  (let [r (sh (str (engine-root) "/bin/state") "flow" "--run" run)]
    (when-not (zero? (:exit r))
      (throw (ex-info (str "could not read the run's flow:\n" (:out r)
                           (when (seq (:err r)) (str "\n" (:err r)))) {})))
    (json/parse-string (:out r) true)))

(defn gate-stage [flow]
  (or (first (filter #(= "gate" (:role %)) (:stages flow)))
      (throw (ex-info "the flow declares no gate stage" {}))))

;; ---- seal ----------------------------------------------------------------
;;
;; The worktree is the run's code, and until it is committed it is not durable:
;; `git diff <base>` silently omits untracked files, so new tests and new source
;; — the bulk of what a run produces — never reach the record or the mirror.
;; Sealing closes that: stage the lot, commit it, and freeze the full diff as
;; worktree.patch. The patch's sha256 is the worktree's identity, and it is what
;; the gate records and the commit law checks.
;;
;; Stage commits are intermediate history. Stage 05 squashes them into the one
;; clean commit that is the run's actual deliverable.

(defn sha256
  "Lowercase hex sha256 of a string's UTF-8 bytes — parity with sha256sum,
   node's crypto, and adapter-fs's worktree_patch::digest."
  [s]
  (->> (.getBytes (str s) "UTF-8")
       (.digest (java.security.MessageDigest/getInstance "SHA-256"))
       (map #(format "%02x" %))
       (apply str)))

(defn seal!
  "Commit whatever the stage left in the worktree and refresh worktree.patch.
   Returns the worktree identity. Idempotent: a clean worktree commits nothing
   and the patch is rewritten unchanged."
  [run label]
  (let [cfg  (edn/read-string (slurp (str run "/run.edn")))
        wt   (str run "/worktree")
        base (:base-commit cfg)]
    (when-not (fs/directory? wt)
      (throw (ex-info (str "no worktree at " wt " — nothing to seal") {})))
    (let [add (sh "git" "-C" wt "add" "-A")]
      (when-not (zero? (:exit add))
        (throw (ex-info (str "git add failed: " (:err add)) {}))))
    ;; `diff --cached --quiet` exits 1 exactly when something is staged.
    (when-not (zero? (:exit (sh "git" "-C" wt "diff" "--cached" "--quiet")))
      (let [c (sh "git" "-C" wt "commit" "-m" (str "wip(" label "): stage output"))]
        (when-not (zero? (:exit c))
          (throw (ex-info (str "git commit failed: " (:out c) " " (:err c)) {})))))
    ;; --binary keeps new/binary files in the patch AND keeps it valid UTF-8
    ;; (git armors binary hunks), so it rides the mirror's text artifact channel.
    (let [patch (:out (p/sh "git" "-C" wt "diff" "--binary" base))
          patch (or patch "")]
      (spit (str run "/worktree.patch") patch)
      ;; Publishing is part of making the stage durable, so it happens here
      ;; rather than waiting for an operator to remember it. Best-effort: no
      ;; mirror configured (or an unreachable one) must never fail a stage.
      (let [n (sh (str (engine-root) "/bin/state") "notify" "--run" run)]
        (when-not (zero? (:exit n))
          (binding [*out* *err*]
            (println (str "note: mirror not updated (" (:cmd-detail n) (:err n) ")")))))
      (sha256 patch))))

(defn seal [{:keys [run stage]}]
  (when-not run (throw (ex-info "seal needs --run RUNDIR" {})))
  (let [id (seal! run (or stage "stage"))]
    (println (json/generate-string {:run-dir run :worktree-id id :sealed true}))))

;; ---- squash --------------------------------------------------------------
;;
;; Stage commits exist so the code survives a host move; they are not the
;; deliverable. Collapsing them back to the base commit leaves every change
;; staged and nothing committed, so the commit stage writes the single clean
;; commit it always wrote. Soft reset only — the worktree's contents, and so
;; its identity, are untouched.

(defn squash [{:keys [run]}]
  (when-not run (throw (ex-info "squash needs --run RUNDIR" {})))
  (let [cfg  (edn/read-string (slurp (str run "/run.edn")))
        wt   (str run "/worktree")
        base (:base-commit cfg)
        before (sha256 (slurp (str run "/worktree.patch")))
        r    (sh "git" "-C" wt "reset" "--soft" base)]
    (when-not (zero? (:exit r))
      (throw (ex-info (str "git reset --soft failed: " (:err r)) {})))
    (let [after (sha256 (:out (p/sh "git" "-C" wt "diff" "--binary" base)))]
      (when-not (= before after)
        (throw (ex-info "squash changed the worktree's content — refusing to continue" {})))
      (println (json/generate-string
                {:run-dir run :squashed-to base :worktree-id after})))))

;; ---- gate ----------------------------------------------------------------
;;
;; Sealing before the gate and recording the identity after it are one
;; operation, so the report can never describe code the gate did not see.

(defn gate [{:keys [run]}]
  (when-not run (throw (ex-info "gate needs --run RUNDIR" {})))
  (let [flow   (run-flow run)
        stage  (gate-stage flow)
        wt     (str run "/worktree")
        script (str run "/stages/" (:dir stage) "/gate.sh")
        report (str run "/stages/" (:dir stage) "/output/" (:artifact stage))
        id     (seal! run (:name stage))
        r      (p/sh {:dir wt} "bash" script)
        body   (str (or (:out r) "") (when (seq (:err r)) (str "\n" (:err r))))]
    (fs/create-dirs (fs/parent report))
    ;; The identity goes in last: the verdict is only ever readable together
    ;; with the code it judged.
    (spit report (str body "\n\nWorktree: " id "\n"))
    (println (json/generate-string
              {:run-dir run :gate-report report :worktree-id id
               :verdict (if (zero? (:exit r)) "green" "red")}))
    (System/exit (:exit r))))

;; ---- setup ---------------------------------------------------------------

(defn setup [{:keys [project spec arm round phase flow]}]
  (when-not (and project spec) (throw (ex-info "setup needs --project and --spec" {})))
  (let [repo    (repo-root)
        flow-dir (resolve-flow flow)
        flow-name (str (fs/file-name flow-dir))
        project (str (fs/absolutize project))
        status  (sh "git" "-C" project "status" "--porcelain")
        arm     (or arm "folder")
        round   (or round "round-0")
        phase   (or phase "steady-state")
        pname   (str (fs/file-name project))
        millis  (System/currentTimeMillis)
        rid     (run-id pname millis)
        branch  (branch-name rid)
        run-root (or (System/getenv "DA_RUN_ROOT")
                     (str (fs/home) "/.cache/directory-algorithm/runs"))
        run-dir (str run-root "/" rid)
        wt      (str run-dir "/worktree")
        base    (:out (sh "git" "-C" project "rev-parse" "HEAD"))
        algver  (let [r (sh "git" "-C" repo "rev-parse" "--short" "HEAD")]
                  (if (zero? (:exit r)) (:out r) "uncommitted-working-tree"))
        pipeline (validate-flow! flow-dir)]
    (when-not (zero? (:exit status))
      (throw (ex-info (str "not a git repository (or git failed) at " project
                           (when (seq (:err status)) (str ": " (:err status)))) {})))

    (when (working-tree-dirty? (:out status))
      (throw (ex-info (str "refusing to run — the target project has uncommitted changes.\n"
                           "Commit or stash them first: the worktree branches from HEAD, so "
                           "uncommitted or untracked files are silently excluded from the run's "
                           "baseline.\n\n" (:out status)) {})))
    (fs/create-dirs run-dir)
    (doseq [f (flow-files flow-dir)]
      (let [src (str flow-dir "/" f), dst (str run-dir "/" f)]
        (if (fs/directory? src)
          (fs/copy-tree src dst {:replace-existing true})
          (fs/copy src dst {:replace-existing true}))))
    ;; The gate DISPATCHER is engine law — every flow gets the same one, so a
    ;; flow cannot quietly weaken how the verdict is rendered. What a flow owns
    ;; is its default-gate.sh (the actual bar), and the project may override
    ;; both with its own .da/gate.
    (let [gate-dir (:dir (gate-stage pipeline))
          dst (str run-dir "/stages/" gate-dir "/gate.sh")]
      (fs/create-dirs (fs/parent dst))
      (fs/copy (str (engine-root) "/gate/dispatch.sh") dst {:replace-existing true})
      (fs/set-posix-file-permissions dst "rwxr-xr-x"))
    (fs/copy (str (fs/absolutize spec)) (str run-dir "/spec.md") {:replace-existing true})
    (let [r (sh "git" "-C" project "worktree" "add" "-b" branch wt "HEAD")]
      (when-not (zero? (:exit r)) (throw (ex-info (str "git worktree add failed: " (:err r)) {}))))
    (spit (str run-dir "/run.edn")
          (pr-str {:run-id rid :project project :branch branch :base-commit base
                   :algorithm-version algver :flow flow-name
                   :contracts (flow-files flow-dir)
                   :spec (str (fs/absolutize spec)) :arm arm :round round :phase phase
                   :created (str (java.time.Instant/ofEpochMilli millis))}))
    (println (json/generate-string
              {:run-id rid :run-dir run-dir :worktree wt :branch branch
               :next ["cd the run dir and open Claude Code there"
                      (str "the agent reads CLAUDE.md then CONTEXT.md; the codebase is ./worktree")
                      (str "status any time: bin/state status --run " run-dir " --pretty")
                      (str "when done: bin/run capture --run " run-dir)]}))))

;; ---- capture -------------------------------------------------------------

(defn capture [{:keys [run round]}]
  (when-not run (throw (ex-info "capture needs --run RUNDIR" {})))
  (let [cfg     (edn/read-string (slurp (str run "/run.edn")))
        round   (or round (:round cfg))
        rid     (:run-id cfg)
        wt      (str run "/worktree")
        out-dir (str (records-root) "/experiments/" round "/runs/" rid)
        ;; Seal first: an unsealed worktree's untracked files (every new test,
        ;; every new source file) are invisible to `git diff` and would be
        ;; frozen out of the record entirely.
        _       (seal! run "capture")
        patch   (slurp (str run "/worktree.patch"))
        greport (let [stage (gate-stage (run-flow run))
                      g (str run "/stages/" (:dir stage) "/output/" (:artifact stage))]
                  (if (fs/exists? g) (slurp g) "(no gate report produced this run)"))
        session-dir (str (fs/home) "/.claude/projects/" (munge-cwd run))
        traces  (when (fs/exists? session-dir)
                  (->> (fs/glob session-dir "*.jsonl") (map str) vec))
        ;; F7/ADR-0029: steer-requests are meter events — freeze each file with the record
        steers  (vec (for [d (sort-by str (fs/list-dir (str run "/stages")))
                           :when (fs/directory? d)
                           :let [f (str d "/output/STEER-REQUEST.md")]
                           :when (fs/exists? f)]
                       {:stage (str (fs/file-name d)) :file f}))]
    (fs/create-dirs (str out-dir "/traces"))
    ;; retries are cost data (F9): freeze the harness's retry log with the record
    (let [rl (str run "/retry-log.edn")]
      (when (fs/exists? rl)
        (fs/copy rl (str out-dir "/retry-log.edn") {:replace-existing true})))
    (when (seq steers)
      (fs/create-dirs (str out-dir "/steers"))
      (doseq [{:keys [stage file]} steers]
        (fs/copy file (str out-dir "/steers/" stage ".md") {:replace-existing true})))
    (spit (str out-dir "/manifest.json")
          (json/generate-string
           (manifest {:run-id rid :project (:project cfg) :branch (:branch cfg)
                      :base-commit (:base-commit cfg) :algorithm-version (:algorithm-version cfg)
                      :contracts (:contracts cfg) :spec (:spec cfg) :arm (:arm cfg)
                      :round round :phase (:phase cfg) :created (:created cfg)
                      :steers (mapv :stage steers)})
           {:pretty true}))
    (spit (str out-dir "/result.patch") patch)
    (spit (str out-dir "/gate-report.md") greport)
    (doseq [t (or traces [])]
      (fs/copy t (str out-dir "/traces/" (fs/file-name t)) {:replace-existing true}))
    (println (json/generate-string
              {:run-id rid :record out-dir
               :patch-bytes (count patch)
               :traces-copied (count (or traces []))
               :traces-note (when-not traces
                              (str "no Claude session found at " session-dir
                                   " — attach traces manually"))}))))

;; ---- restore -------------------------------------------------------------

(defn copy-missing!
  "Copy every file under src that the destination does not already hold. The
   mirror is authoritative for anything it carried; the flow only fills gaps."
  [src dst]
  (doseq [f (fs/glob src "**")]
    (let [rel (str (fs/relativize src f))
          to  (str dst "/" rel)]
      (when-not (or (fs/directory? f) (fs/exists? to))
        (fs/create-dirs (fs/parent to))
        (fs/copy f to)))))

(defn restore [{:keys [run-id into flow]}]
  (when-not run-id (throw (ex-info "restore needs --run-id RUNID" {})))
  (let [run-root (or (System/getenv "DA_RUN_ROOT")
                     (str (fs/home) "/.cache/directory-algorithm/runs"))
        run-dir (str (or into (str run-root "/" run-id)))]
    (when (fs/exists? (str run-dir "/run.edn"))
      (throw (ex-info (str run-dir " already holds a run — refusing to overwrite") {})))
    ;; The mirror comes first — it alone knows which flow built this run — and
    ;; it stays authoritative. The flow then fills in only what the mirror does
    ;; not carry: the contracts, references, and stage CONTEXT.md files.
    (fs/create-dirs run-dir)
    (let [r (sh (str (engine-root) "/bin/state") "restore" "--run-id" run-id "--into" run-dir)]
      (when-not (zero? (:exit r))
        (throw (ex-info (str "state restore failed:\n" (:out r)
                             (when (seq (:err r)) (str "\n" (:err r)))) {}))))
    (let [named (:flow (edn/read-string (slurp (str run-dir "/run.edn"))))
          flow-dir (resolve-flow (or flow named))]
      (copy-missing! flow-dir run-dir)
      (let [gate-dir (:dir (gate-stage (run-flow run-dir)))
            dst (str run-dir "/stages/" gate-dir "/gate.sh")]
        (fs/create-dirs (fs/parent dst))
        (fs/copy (str (engine-root) "/gate/dispatch.sh") dst {:replace-existing true})
        (fs/set-posix-file-permissions dst "rwxr-xr-x")))
    ;; The code comes back from worktree.patch, not from the origin host's
    ;; branch: that branch is never pushed, so it does not exist here. The
    ;; patch is base-relative, so any clone holding the base commit will do.
    (let [cfg     (edn/read-string (slurp (str run-dir "/run.edn")))
          project (:project cfg)
          wt      (str run-dir "/worktree")
          patch   (str run-dir "/worktree.patch")
          base    (:base-commit cfg)
          have?   (and (fs/directory? project)
                       (zero? (:exit (sh "git" "-C" project "cat-file" "-e"
                                         (str base "^{commit}")))))
          rebuilt (when have?
                    (let [w (sh "git" "-C" project "worktree" "add" "-b" (:branch cfg) wt base)]
                      (when-not (zero? (:exit w))
                        (throw (ex-info (str "git worktree add failed: " (:err w)) {})))
                      (when (and (fs/exists? patch) (seq (str/trim (slurp patch))))
                        (let [a (sh "git" "-C" wt "apply" "--binary" patch)]
                          (when-not (zero? (:exit a))
                            (throw (ex-info (str "worktree.patch did not apply cleanly: "
                                                 (:err a)) {})))))
                      true))]
      (println (json/generate-string
                (merge {:run-id run-id :run-dir run-dir :worktree-restored (boolean rebuilt)}
                       (if rebuilt
                         {:next [(str "the worktree is rebuilt at " wt
                                      " (base " base " + worktree.patch)")
                                 (str "status any time: bin/state status --run " run-dir " --pretty")]}
                         {:next [(str "no clone of " project " holding base commit " base
                                      " on this machine — restore the code by hand:")
                                 (str "  git -C <clone> worktree add -b " (:branch cfg) " " wt " " base)
                                 (str "  git -C " wt " apply --binary " patch)
                                 (str "status any time: bin/state status --run " run-dir " --pretty")]})))))))

;; ---- dispatch ------------------------------------------------------------

(try
  (let [{:keys [cmd] :as flags} (parse-flags *command-line-args*)]
    (case cmd
      "selftest" (selftest)
      "setup"    (setup flags)
      "seal"     (seal flags)
      "squash"   (squash flags)
      "gate"     (gate flags)
      "capture"  (capture flags)
      "restore"  (restore flags)
      (do (binding [*out* *err*]
            (println "usage: bin/run setup --project P --spec S [--arm folder] [--round R]")
            (println "       bin/run capture --run RUNDIR [--round R]")
            (println "       bin/run restore --run-id RUNID [--into DIR]")
            (println "       bin/run --selftest"))
          (System/exit 2))))
  (catch clojure.lang.ExceptionInfo e
    (binding [*out* *err*] (println "error:" (ex-message e)))
    (System/exit 2)))
